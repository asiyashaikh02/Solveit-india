rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Campaigns - Publicly readable, admin writable
    match /campaigns/{campaignId} {
      allow read: if true; // Campaigns are public
      allow write: if isAdmin();
    }

    // User Interactions - Publicly writable (with rate limit / specific fields), admin readable
    match /user_interactions/{interactionId} {
      allow create: if true; // Allow anonymous tracking
      allow read: if isAdmin();
    }

    // Expert Profiles - Publicly readable, owner writable
    match /experts/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
