# --- AI STUDIO / LOCAL CONFIG ---
# GEMINI_API_KEY: Injected automatically by AI Studio.
# For local dev, copy your key from AI Studio settings.
GEMINI_API_KEY=

# --- FIREBASE (VITE_ PREFIX REQUIRED) ---
# When deploying to Vercel/Netlify, set these in the dashboard:
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Specific Firestore database ID (default is '(default)')
VITE_FIREBASE_DATABASE_ID=(default)

# --- FALLBACK / DEMO MODE ---
# Set to 'true' to bypass Firebase and use mock data services.
# Highly recommended for development and initial previews.
VITE_USE_FIREBASE_MOCK=true
